<div x-data="{ tareas: [], nueva: '' }" x-init="fetch('/tareas')    
    .then(r => r.json()).then(d => tareas = d)"> <!--  lo que va a manejar este div son datos -->

    <!-- se va a crear tareas una lista vacia y tambien el mensaje vacio para luego agregarle algo -->


    <!-- Luego  con el fetch va servidor flask donde obtiene los datos
     luego los transforma en JSON y finalmente guarda en variable tareas -->


  <ul>   <!-- Este ul actua como un for-->
    <template x-for="tarea in tareas" :key="tarea"> <!-- por cada tarea en la lista, crea un elemento-->
      <li x-text="tarea"></li>  <!--muestra el texto de esa tarea como un item de lista-->
    </template>
  </ul>

  <!-- recuadro donde se guarda la info -->
  <input x-model="nueva" placeholder="Nueva tarea">  <!-- significa que todo lo que el usuario escriba se guarda automáticamente en la variable nueva en tiempo real-->
  <button @click="tareas.push(nueva); nueva=''">Agregar</button>
  <!-- leugo de hacer el click  agrega lo que esta en la var "nueva" a la lista de tareas  y luego se limpia el campo de texto para que quede vacío de nuevo-->
</div>